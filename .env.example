# Hadar.ma — Environment variables template
# Copy to .env.local (git-ignored) and fill in real values. NEVER commit secrets.
#
# Pour générer des clés cryptographiques aléatoires :
#   node scripts/generate-secrets.mjs
# Ce script écrit les valeurs prêtes à coller dans .env.local

# ── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (DigitalOcean Managed PostgreSQL en prod, Neon en dev) ──────
# DATABASE_URL utilise le pooler (pgbouncer=true requis côté Prisma).
# DIRECT_URL contourne le pooler pour les migrations.
DATABASE_URL="postgresql://user:password@HOST-pooler/dbname?sslmode=require&pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://user:password@HOST/dbname?sslmode=require"

# ── Redis (sessions, cache, rate limiting) ───────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth (JWT signing keys) ──────────────────────────────────────────────
# Générer avec : openssl rand -base64 64   (chacun)
# Rotation : chaque clé peut être tournée indépendamment, mais les
# tokens signés avec l'ancienne clé deviennent invalides → tous les
# users sont déconnectés. Faire en heures creuses.
AUTH_JWT_SECRET=
AUTH_REFRESH_SECRET=

# ── Crypto (chiffrement champ-par-champ + hashing peppered) ──────────────
# Toutes ces clés DOIVENT être en base64, 32 octets (= 44 chars b64).
# Générer avec : node scripts/generate-secrets.mjs
#
# 🔒 ENCRYPTION_KEY : clé AES-256-GCM pour les champs T1 (CIN/selfie
#    object keys, secrets TOTP, payload audit, notes admin sur signalements,
#    etc.). En production, à migrer vers DigitalOcean KMS — ce champ
#    sera alors un identifiant de clé KMS au lieu de la clé brute.
ENCRYPTION_KEY=

# 🔒 CONTACT_HASH_PEPPER : pepper HMAC-SHA256 pour calculer le
#    contactValueHash (recherche indexée sans révéler le contact en
#    clair). Une fuite SQL seule est inexploitable sans cette pepper.
CONTACT_HASH_PEPPER=

# 🔒 IP_HASH_PEPPER : pepper séparé pour hasher les IPs et UAs dans
#    Session / AuditLog / LoginAttempt / ShortLivedToken. Permet le
#    grouping (même IP) sans stocker l'IP brute.
IP_HASH_PEPPER=

# ── Object storage (DigitalOcean Spaces pour les évidences) ─────────────
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_REGION=fra1
SPACES_BUCKET=hadar-uploads
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=

# ── Email transactionnel ─────────────────────────────────────────────────
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS="Hadar.ma <no-reply@hadar.ma>"

# ── WhatsApp Business Cloud API (Meta) ───────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ── Telegram Bot ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── Seed (dev local uniquement) ──────────────────────────────────────────
SEED_SUPERADMIN_EMAIL=superadmin@hadar.ma
SEED_SUPERADMIN_PASSWORD=
