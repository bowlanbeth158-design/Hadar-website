# Hadar.ma — Environment variables template
# Copy to .env.local (git-ignored) and fill in real values. NEVER commit secrets.

# ── Application ──────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (DigitalOcean Managed PostgreSQL in prod) ───────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/hadar?schema=public"

# ── Redis (sessions, cache, rate limiting) ───────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth (JWT signing keys, rotated) ─────────────────────────────────────
# Generate with: openssl rand -base64 64
AUTH_JWT_SECRET=
AUTH_REFRESH_SECRET=

# ── Object storage (DigitalOcean Spaces for report evidence) ─────────────
SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com
SPACES_REGION=fra1
SPACES_BUCKET=hadar-uploads
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=

# ── Email provider (transactional + marketing) ───────────────────────────
# Options: sendgrid | resend | mailgun | smtp
EMAIL_PROVIDER=resend
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS="Hadar.ma <no-reply@hadar.ma>"

# ── WhatsApp Business Cloud API (Meta) ───────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ── Telegram Bot (outbound announcements) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# ── Seed (local development only) ────────────────────────────────────────
SEED_SUPERADMIN_EMAIL=superadmin@hadar.ma
SEED_SUPERADMIN_PASSWORD=
